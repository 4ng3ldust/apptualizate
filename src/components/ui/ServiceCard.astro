---
interface Props {
  title: string;
  description: string;
  href: string;
  phase?: number;
  icon?: string;
}

const { title, description, href, phase, icon = '→' } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col p-6 bg-white rounded-2xl border border-neutral-200 hover:border-primary-200 hover:shadow-lg transition-all duration-200"
>
  <div class="flex items-start justify-between mb-4">
    {phase && (
      <span class="text-xs font-semibold uppercase tracking-widest text-accent-500">
        Phase {phase}
      </span>
    )}
    <span class="text-2xl">{icon}</span>
  </div>
  <h3 class="font-heading font-bold text-lg text-primary-900 mb-2 group-hover:text-primary-600 transition-colors">
    {title}
  </h3>
  <p class="text-sm text-neutral-600 flex-1">{description}</p>
  <div class="mt-4 flex items-center text-sm font-medium text-primary-600 group-hover:gap-2 transition-all">
    <span>Learn more</span>
    <span class="ml-1 group-hover:translate-x-1 transition-transform">→</span>
  </div>
</a>
